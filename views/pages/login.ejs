<% var title = 'Login | Adv Turbo'; %>
<!DOCTYPE html>
<html lang="pt-br">
  <%- include('../partials/head', { title: title }) %>
  <body>
    <%- include('../partials/navbar') %>
    <section class="container" style="padding-top: 10rem; padding-bottom: 4rem;">
      <div class="row justify-content-center">
        <div class="col-md-5">
          <div class="card shadow-lg p-4">
            <h3 class="mb-4 fw-bold">Painel de Advogados</h3>
            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <form action="/login" method="post">
              <div class="mb-3">
                <label class="form-label">Usuário</label>
                <input name="email" type="email" class="form-control" placeholder="e-mail" required />
              </div>
              <div class="mb-3">
                <label class="form-label">Senha</label>
                <input name="password" type="password" class="form-control" placeholder="*******" required />
              </div>
              <button class="btn btn-primary w-100" type="submit">Entrar</button>
            </form>
            <p class="text-muted mt-3 mb-0">Esqueceu a senha? Entre em contato com o backoffice.</p>
          </div>
        </div>
      </div>
    </section>
    <%- include('../partials/footer') %>
  </body>
</html>
