<% var title = 'Adv Turbo - Advocacia Digital'; %>
<!DOCTYPE html>
<html lang="pt-br">
  <%- include('../partials/head', { title: title }) %>
  <body>
    <%- include('../partials/navbar') %>

    <section id="home">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-6">
            <h1 class="display-4 fw-bold mb-4">Advocacia Digital: O Futuro do seu Negócio.</h1>
            <p class="lead mb-4 text-light">Assessoria jurídica completa para empresas e pessoas físicas, com a facilidade de um clique.</p>
            <div class="d-flex gap-3">
              <a href="#planos" class="btn btn-primary btn-lg px-4">Ver Planos</a>
              <a href="#cadastro" class="btn btn-outline-light btn-lg px-4">Cadastre-se</a>
            </div>
            <% if (contatoMessage) { %>
              <div class="alert alert-success mt-4" role="alert"><%= contatoMessage %></div>
            <% } %>
          </div>
          <div class="col-lg-6 hero-image-container">
            <img src="/img/balanca.png" alt="Balança e Celular" class="responsive-hero-img" />
          </div>
        </div>
      </div>
    </section>

    <section id="servicos">
      <div class="container">
        <div class="text-center mb-5">
          <h2 class="fw-bold">Nossas Soluções Jurídicas</h2>
          <p class="text-muted">Serviços especializados com tecnologia de ponta.</p>
        </div>
        <div class="row g-4">
          <% services.forEach(function(service) { %>
            <div class="col-md-4">
              <div class="service-box">
                <i class="fas <%= service.icon %> service-icon"></i>
                <h4><%= service.title %></h4>
                <p><%= service.description %></p>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </section>

    <section id="depoimentos">
      <div class="container">
        <h2 class="text-center mb-5 fw-bold">Nossa Equipe de Especialistas</h2>
        <div id="testimonyCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <% testimonyPeople.forEach(function(person, index) { %>
              <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                <img src="/img/<%= person.image %>" alt="<%= person.name %>" />
                <div class="testimonial-overlay">
                  <h4 class="fw-bold"><%= person.name %></h4>
                  <p class="fs-5"><%= person.quote %></p>
                </div>
              </div>
            <% }); %>
          </div>
          <button class="carousel-control-prev" type="button" data-bs-target="#testimonyCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#testimonyCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
          </button>
        </div>
      </div>
    </section>

    <section id="planos">
      <div class="container">
        <h2 class="text-center mb-5 fw-bold">Planos de Assessoria</h2>
        <div class="row g-4">
          <% heroPlans.forEach(function(plan) { %>
            <div class="col-md-4">
              <div class="payment-card h-100">
                <div class="card-header-custom">
                  <h3 class="p-4 m-0"><%= plan.title %></h3>
                </div>
                <div class="p-4">
                  <div class="price-tag mb-3 fs-4"><%= plan.price %></div>
                  <ul class="list-unstyled text-start mb-4">
                    <% plan.perks.forEach(function(perk) { %>
                      <li><i class="fas fa-check text-success me-2"></i><%= perk %></li>
                    <% }); %>
                  </ul>
                  <a href="https://www.hotmart.com" class="btn btn-hotmart">Comprar na Hotmart</a>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </section>

    <section id="pagamentos" class="py-5">
      <div class="container">
        <h2 class="text-center fw-bold mb-4">Pagamentos Flexíveis</h2>
        <div class="row g-3 justify-content-center">
          <% paymentOptions.forEach(function(option) { %>
            <div class="col-md-4">
              <div class="payment-card" style="border-color: <%= option.color %>">
                <i class="fas <%= option.icon %> fa-2x" style="color: <%= option.color %>"></i>
                <h5 class="mt-3 mb-2"><%= option.method %></h5>
                <p class="text-muted"><%= option.description %></p>
                <button class="btn btn-outline-dark">Conectar minha conta</button>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    </section>

    <section id="communication-panel" class="container mt-5">
      <div class="row">
        <div class="col-lg-6">
          <h3>Plataforma de Comunicação</h3>
          <p>
            Tela colaborativa para advogados, clientes e tarefas. Mensagens, prazos e documentos centralizados em um painel seguro.
          </p>
          <ul class="list-unstyled">
            <li><i class="fas fa-comments me-2 text-info"></i>Chat com histórico criptografado</li>
            <li><i class="fas fa-calendar-check me-2 text-info"></i>Agenda compartilhada</li>
            <li><i class="fas fa-file-contract me-2 text-info"></i>Documentos e notificações</li>
          </ul>
        </div>
        <div class="col-lg-6">
          <form action="/contato" method="post">
            <div class="mb-3">
              <label class="form-label text-dark fw-bold">Nome</label>
              <input class="form-control" name="name" required />
            </div>
            <div class="mb-3">
              <label class="form-label text-dark fw-bold">E-mail</label>
              <input type="email" class="form-control" name="email" required />
            </div>
            <div class="mb-3">
              <label class="form-label text-dark fw-bold">Mensagem</label>
              <textarea class="form-control" name="message" rows="4" required></textarea>
            </div>
            <button class="btn btn-primary w-100" type="submit">Enviar</button>
          </form>
        </div>
      </div>
    </section>

    <section id="cadastro">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-md-6 text-center">
            <h2 class="fw-bold mb-4">Cadastre-se para Consultoria</h2>
            <form action="/cadastrar" method="post">
              <input type="text" class="form-control" placeholder="Nome Completo" name="fullname" required />
              <input type="email" class="form-control" placeholder="Seu melhor e-mail" name="email" required />
              <input type="tel" class="form-control" placeholder="Telefone / WhatsApp" name="phone" required />
              <select class="form-select" name="type">
                <option>Selecione o tipo de atendimento</option>
                <option value="pj">Pessoa Jurídica</option>
                <option value="pf">Pessoa Física</option>
              </select>
              <button type="submit" class="btn btn-primary btn-lg w-100 mt-3">Enviar Solicitação</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <section id="social">
      <div class="container">
        <div class="social-icons mb-4">
          <a href="https://www.instagram.com" class="social-link"><i class="fab fa-instagram"></i></a>
          <a href="https://www.linkedin.com" class="social-link"><i class="fab fa-linkedin"></i></a>
          <a href="https://www.facebook.com" class="social-link"><i class="fab fa-facebook"></i></a>
          <a href="https://www.whatsapp.com" class="social-link"><i class="fab fa-whatsapp"></i></a>
        </div>
        <p class="small text-secondary m-0">&copy; 2026 Advocacia Digital Turbo. OAB/RJ 000.000 / Eduardo Raymond Beniste</p>
      </div>
    </section>

    <%- include('../partials/footer') %>
  </body>
</html>
