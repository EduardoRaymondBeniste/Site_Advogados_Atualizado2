<% var title = 'Painel | Adv Turbo'; %>
<!DOCTYPE html>
<html lang="pt-br">
  <%- include('../partials/head', { title: title }) %>
  <body>
    <%- include('../partials/navbar') %>
    <section class="container" style="padding-top: 10rem; padding-bottom: 4rem;">
      <div class="row">
        <div class="col-lg-12 mb-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <h2>Painel Dev</h2>
              <p class="text-muted">Comunicação segura entre advogados e clientes, pagamentos e agendamentos.</p>
            </div>
            <% if (notification) { %>
              <span class="badge rounded-pill bg-success"><%= notification %></span>
            <% } %>
          </div>
        </div>
      </div>
      <div class="row g-4">
        <div class="col-md-6">
          <div class="card p-4 shadow-sm">
            <h5 class="fw-bold">Cadastrar novo cliente</h5>
            <form>
              <input class="form-control mb-2" placeholder="Nome completo" />
              <input class="form-control mb-2" placeholder="CPF / CNPJ" />
              <input class="form-control mb-2" placeholder="E-mail" />
              <button class="btn btn-outline-primary w-100" type="button">Salvar cliente</button>
            </form>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card p-4 shadow-sm">
            <h5 class="fw-bold">Cadastrar novo advogado</h5>
            <form>
              <input class="form-control mb-2" placeholder="Nome completo" />
              <input class="form-control mb-2" placeholder="OAB" />
              <input class="form-control mb-2" placeholder="Especialidade" />
              <button class="btn btn-outline-primary w-100" type="button">Salvar advogado</button>
            </form>
          </div>
        </div>
      </div>
      <div class="row g-4 mt-2">
        <div class="col-md-6">
          <div class="card p-4 shadow-sm">
            <h5 class="fw-bold">Criar post &amp; comentários</h5>
            <form>
              <input class="form-control mb-2" placeholder="Título" />
              <textarea class="form-control mb-2" rows="3" placeholder="Resumo"></textarea>
              <button class="btn btn-warning w-100" type="button">Publicar no blog</button>
            </form>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card p-4 shadow-sm">
            <h5 class="fw-bold">Agendamento de tarefas</h5>
            <form action="/agendar" method="post">
              <input class="form-control mb-2" name="tarefa" placeholder="Título da tarefa" />
              <input class="form-control mb-2" name="data" type="date" />
              <input class="form-control mb-2" name="responsavel" placeholder="Responsável" />
              <button class="btn btn-outline-success w-100" type="submit">Agendar</button>
            </form>
          </div>
        </div>
      </div>
    </section>
    <%- include('../partials/footer') %>
  </body>
</html>
